# Copy to .env and fill in. Never commit the .env file itself.

# Required: model provider
ANTHROPIC_API_KEY=

# Optional: alternative providers
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=

# Optional: web backend (only what your config.yaml uses)
# TAVILY_API_KEY=
# FIRECRAWL_API_KEY=
# EXA_API_KEY=

# Optional: integrations a specific profile may need
# SLACK_BOT_TOKEN=
# DISCORD_BOT_TOKEN=
# GITHUB_TOKEN=
